@model IEnumerable<CasoPractico1.Abstracciones.ModelosParaUI.EspecialidadesDTO>

@{
    ViewBag.Title = "Listado de Especialidades";
}

<h2>Listado de Especialidades</h2>

<p>
    @Html.ActionLink("Crear Nueva Especialidad", "CrearEspecialidades")
</p>

<table class="table">
    <tr>
        <th>@Html.DisplayNameFor(model => model.Id)</th>
        <th>@Html.DisplayNameFor(model => model.Nombre)</th>
        <th>@Html.DisplayNameFor(model => model.Descripcion)</th>
        <th>Acciones</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.Id)</td>
            <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
            <td>@Html.DisplayFor(modelItem => item.Descripcion)</td>
        <td>
            @Html.ActionLink("Editar", "EditarEspecialidades", new { id = item.Id }) |
            @Html.ActionLink("Detalles", "DetallesEspecialidades", new { id = item.Id }) |
            @Html.ActionLink("Eliminar", "EliminarEspecialidades", new { id = item.Id })
        </td>
        </tr>
    }
</table>