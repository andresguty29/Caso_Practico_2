@model CasoPractico1.Abstracciones.ModelosParaUI.BuscarCitaDTO

@{
    ViewBag.Title = "DetallesCitas";
}

<h2>DetallesCitas</h2>

<div>
    <h4>BuscarCitaDTO</h4>
    <hr />
    <dl class="dl-horizontal">


        <dt>
            @Html.DisplayNameFor(model => model.NombreDeLaPersona)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.NombreDeLaPersona)
        </dd>


        <dt>
            @Html.DisplayNameFor(model => model.Telefono)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Telefono)
        </dd>


        <dt>
            @Html.DisplayNameFor(model => model.Correo)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Correo)
        </dd>




        <dt>
            @Html.DisplayNameFor(model => model.Identificacion)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Identificacion)
        </dd>



        <dt>
            @Html.DisplayNameFor(model => model.FechaNacimiento)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.FechaNacimiento)
        </dd>



        <dt>
            @Html.DisplayNameFor(model => model.Direccion)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Direccion)
        </dd>



        <dt>Nombre del Servicio:</dt>

        <dd>
            @Html.DisplayFor(model => model.Nombre)
        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Especialidad)
        </dt>

        <dd>

            @if (Model.Especialidad == 1)
            {
                <text>Medicina General</text>
            }
            else if (Model.Especialidad == 2)
            {
                <text>Imagenología</text>
            }
            else if (Model.Especialidad == 3)
            {
                <text>Microbiología</text>
            }


        </dd>

        <dt>
            @Html.DisplayNameFor(model => model.Especialista)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Especialista)
        </dd>


        <dt>
            @Html.DisplayNameFor(model => model.MontoTotal)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.MontoTotal)
        </dd>




        <dt>
            @Html.DisplayNameFor(model => model.FechaDeLaCita)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.FechaDeLaCita)
        </dd>

        <dt>Fecha reservacion:</dt>

        <dd>
            @Html.DisplayFor(model => model.FechaDeRegistroCita)
        </dd>
















    </dl>
</div>

